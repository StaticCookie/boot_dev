## Child inherits by adding (Human) into the brackets and the Super().__init__(name) inherits the name function

class Human:
    def __init__(self, name):
        self.__name = name

    def get_name(self):
        return self.__name

class Archer(Human):
    def __init__(self, name, num_arrows):
        super().__init__(name)
        self.__num_arrows = num_arrows
        
    def get_num_arrows(self):
        return self.__num_arrows
